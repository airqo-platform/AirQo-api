# device-registry — example environment file (development defaults)
# Copy to .env.development (or .env.{environment}) and fill in secrets.
# See .env.consolidated.template for descriptions of every variable.
# Keys are canonical (no environment prefix).

NODE_ENV=development

# Core Secrets
TS_API_KEY=
JWT_SECRET=
SESSION_SECRET=
KEY_ENCRYPTION_KEY=
ADMIN_SETUP_SECRET=

# ThingSpeak
WRITE=
READ=
CHANNEL=
THINGSPEAK_BASE_URL=https://api.thingspeak.com

# Database (MongoDB)
MONGO_URI=mongodb://localhost/
COMMAND_MONGO_URI=mongodb://localhost/
QUERY_MONGO_URI=mongodb://localhost/
DB_NAME=device-registry
MONGO_GCE_URI=
MONGO_TEST=device-registry
MONGODB_POOL_SIZE=
MONGODB_BUFFER_TIMEOUT_MS=

# Redis
REDIS_SERVER=127.0.0.1
REDIS_PORT=6379
REDIS_URL=

# Cloudinary / GCP
CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
GCP_KEY=

# External APIs
GOOGLE_MAPS_API_KEY=
TAHMO_API_CREDENTIALS_USERNAME=
TAHMO_API_CREDENTIALS_PASSWORD=
TAHMO_API_GET_STATIONS_URL=https://datahub.tahmo.org/services/assets/v2/stations
GITGUARDIAN_API_KEY=
MOESIF_APPLICATION_ID=

# Platform URLs
PLATFORM_BASE_URL=https://platform.airqo.net
MAPS_GOOGLEAPIS_BASE_URL=https://maps.googleapis.com
# Leave blank for public Nominatim instance (https://nominatim.openstreetmap.org).
NOMINATIM_BASE_URL=

# Application
PORT=3000
N_VALUES=500
NAME=device-registry
LICENSE_ID=

# Tenants & Networks
TENANTS=airqo
NETWORKS=kcca,airqo,ub,usembassy,nasa,cross,nairobi,fortportal,nema,mukwano,urbanbetter,saaqis,rema,ema
DEFAULT_NETWORK=airqo
DEFAULT_TENANT=airqo

# Kafka
KAFKA_CLIENT_ID=dev-device-registry-raw-measurements-consumer-id
KAFKA_CLIENT_GROUP=dev-raw-measurements-consumer-group
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPICS=kcca-transformed-device-measurements-topic
SCHEMA_REGISTRY=http://localhost:8081/
KAFKA_RAW_MEASUREMENTS_TOPICS=airqo-streams-transformed-device-measurements-topic,kcca-streams-transformed-device-measurements-topic
UNIQUE_CONSUMER_GROUP=my-unique-consumer-group
UNIQUE_PRODUCER_GROUP=my-unique-producer-group

# Kafka Topics
NETWORK_EVENTS_TOPIC=network-events-topic
SITES_TOPIC=sites-topic
DEVICES_TOPIC=devices-topic
LOCATIONS_TOPIC=locations-topic
SENSORS_TOPIC=sensors-topic
AIRQLOUDS_TOPIC=airqlouds-topic
ACTIVITIES_TOPIC=activities-topic
PHOTOS_TOPIC=photos-topic
TIPS_TOPIC=tips-topic
KYA_TOPIC=kya-topic
KYA_LESSON=kya-lesson
KYA_QUIZ=kya-quiz
KYA_QUESTION=kya-question
KYA_ANSWER=kya-answer
HOURLY_MEASUREMENTS_TOPIC=hourly-measurements-topic
GRID_TOPIC=grid-topic
COHORT_TOPIC=cohort-topic
GROUPS_TOPIC=groups-topic
DEPLOY_TOPIC=deploy-topic
RECALL_TOPIC=recall-topic

# Activity / Maintenance Types
ACTIVITY_TYPES=recallment,maintenance,deployment,site-creation
MAINTENANCE_TYPES=preventive,corrective
RECALL_TYPES=errors,disconnected

# Device Configuration
DEFAULT_DEVICE_IMAGE=https://res.cloudinary.com/dbibjvyhm/image/upload/v1679207834/
DEVICE_NAMES_TO_EXCLUDE_FROM_JOB=aqg500000_design_test_

# Query Limits
DEFAULT_EVENTS_LIMIT=1000
DEFAULT_EVENTS_SKIP=0
EVENTS_CACHE_LIMIT=1800
DEFAULT_LIMIT_FOR_QUERYING_SITES=1000
DEFAULT_LIMIT_FOR_QUERYING_AIRQLOUDS=1000
DEFAULT_LIMIT_FOR_QUERYING_PHOTOS=1000
DEFAULT_LIMIT_FOR_QUERYING_TIPS=1000
DEFAULT_LIMIT_FOR_QUERYING_KYA_TASKS=1000
DEFAULT_LIMIT_FOR_QUERYING_KYA_LESSONS=1000
DEFAULT_LIMIT_FOR_QUERYING_KYA_QUIZZES=1000
DEFAULT_LIMIT_FOR_QUERYING_KYA_QUESTIONS=1000
DEFAULT_LIMIT_FOR_QUERYING_KYA_ANSWERS=1000
DEFAULT_NEAREST_SITE_RADIUS=5

# Data Quality
DATA_COMPLETENESS_THRESHOLD=80
INTRA_CORRELATION_THRESHOLD=0.98
INTER_CORRELATION_THRESHOLD=0.98
INTER_CORRELATION_PARAMETER=pm2_5
COLLOCATION_CELERY_MINUTES_INTERVAL=10
EXPECTED_RECORDS_PER_HOUR=30

# Historical Data Thresholds
HISTORICAL_OPTIMAL_DAYS=7
HISTORICAL_WARNING_DAYS=30
HISTORICAL_RECENT_DAYS=14
HISTORICAL_ACCEPTABLE_DAYS=90
HISTORICAL_SLOW_DAYS=365
HISTORICAL_REDIRECT_DAYS=730

# Job Schedulers
PRECOMPUTE_ACTIVITIES_JOB_ENABLED=
BACKFILL_SITE_METADATA_SCHEDULER_ENABLED=false
FIND_DUPLICATE_COHORTS_SCHEDULER_ENABLED=true

# Testing
TEST_DATE=2022-12-20T11:43:18.595Z

# Data Warehouse
DATAWAREHOUSE_RAW_DATA=airqo-250220.raw_data
DATAWAREHOUSE_PROJECT=airqo-250220
DATAWAREHOUSE_METADATA=airqo-250220.metadata_stage
DATAWAREHOUSE_AVERAGED_DATA=airqo-250220.averaged_data_stage
BIG_QUERY_LOCATION=EU

# BigQuery Tables
BIGQUERY_DEVICE_UPTIME_TABLE=airqo-250220.averaged_data_stage.device_uptime
BIGQUERY_SITES=airqo-250220.metadata_stage.sites
BIGQUERY_AIRQLOUDS_SITES=airqo-250220.metadata_stage.airqlouds_sites
BIGQUERY_AIRQLOUDS=airqo-250220.metadata_stage.airqlouds
BIGQUERY_GRIDS_SITES=airqo-250220.metadata_stage.grids_sites
BIGQUERY_GRIDS=airqo-250220.metadata_stage.grids
BIGQUERY_COHORTS_DEVICES=airqo-250220.metadata_stage.cohorts_devices
BIGQUERY_COHORTS=airqo-250220.metadata_stage.cohorts
BIGQUERY_RAW_DATA=airqo-250220.raw_data_stage.device_measurements
BIGQUERY_HOURLY_DATA=airqo-250220.averaged_data_stage.hourly_device_measurements
BIGQUERY_DEVICES=airqo-250220.metadata_stage.devices

# Presto
PRESTO_HOST=your-presto-instance-ip
PRESTO_PORT=8080
PRESTO_USER=presto
PRESTO_AUTH_USER=your-presto-auth-user
PRESTO_AUTH_PASSWORD=your-presto-auth-password

# Observability
SLACK_TOKEN=
SLACK_CHANNEL=notifs-device-registry
SLACK_USERNAME=device-registry
ALLOWED_ORIGINS=https://staging.airqo.net/,https://airqo.net/,https://platform.airqo.net/
DOMAIN_WHITELIST=https://staging.airqo.net/,https://airqo.net/,https://platform.airqo.net/

# Inter-service
AUTH_SERVICE_URL=http://localhost:3001/users
INTER_SERVICE_TOKEN=your_secret_inter_service_token
ADMIN_MIGRATION_KEY=your_super_secret_migration_key
DEPLOYMENT_URL=https://staging-netmanager.airqo.net
SERVICE_JWT_TOKEN=your_secret_service_jwt_token
API_BASE_URL=http://localhost:3000
API_TOKEN=your_dev_api_token

# GCP / OAuth
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MONGO_DB_ADMIN_VM_USERNAME=
MONGO_DB_ADMIN_VM_PASSWORD=

# Analytics
ANALYTICS_PRODUCTION_BASE_URL=
ANALYTICS_STAGING_BASE_URL=
ANALYTICS_DEV_BASE_URL=

# Application Defaults
DEFAULT_COHORT=64ca6b009a46986117a5ac12
# Comma-separated cohort names blocked from user/group assignment ("airqo" is always blocked).
PROTECTED_COHORT_NAMES=
HCAPTCHA_SECRET_KEY=
